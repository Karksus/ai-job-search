# SMTP (Gmail) — global fallback if profile doesn't define its own
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# LLM (OpenAI-compatible)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Max jobs to process per day (default: 10)
MAX_JOBS=10

# Optional: Comma-separated list of employers to ignore (case-insensitive)
# IGNORED_EMPLOYERS="Crossing Hurdles,Some Other Agency"

# Per-profile SMTP is configured in profiles.json:
# {
#   "pedro": {
#     "smtp_email": "pedroaserio@gmail.com",
#     "smtp_password": "his-app-password",
#     "recipient_email": "pedroaserio@gmail.com",
#     ...
#   },
#   "ana": {
#     "smtp_email": "dasilvaana.carolinaa@gmail.com",
#     "smtp_password": "her-app-password",
#     "recipient_email": "dasilvaana.carolinaa@gmail.com",
#     ...
#   }
# }
# If smtp_password is empty in profiles.json, falls back to .env credentials.
