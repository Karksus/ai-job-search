{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["CLAUDE.md", "AGENTS.md"],
  "skills": {
    "paths": [".claude/skills", ".agents/skills"]
  },
  "references": {
    "profile": {
      "path": ".claude/skills/job-application-assistant",
      "description": "Candidate profile, evaluation framework, CV/cover letter templates, and interview prep"
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "bun *": "allow",
      "bun run *": "allow",
      "python salary_lookup.py *": "allow",
      "python3 salary_lookup.py *": "allow",
      "pdftotext *": "allow",
      "lualatex *": "allow",
      "xelatex *": "allow",
      "ls *": "allow",
      "git *": "allow"
    },
    "skill": {
      "*": "allow"
    }
  }
}
